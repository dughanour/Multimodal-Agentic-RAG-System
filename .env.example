# LLM Provider - Get your key at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Web Search - Get your key at https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here

# Database Connection (for local development, used when running backend outside Docker)
DATABASE_URL=postgresql+psycopg://rag_user:rag_password@localhost:5433/rag_db
